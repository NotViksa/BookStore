@{
    ViewData["Title"] = "Admin Dashboard";
    var totalUsers = ViewBag.Stats?.TotalUsers ?? 0;
    var totalBooks = ViewBag.Stats?.TotalBooks ?? 0;
    var totalOrders = ViewBag.Stats?.TotalOrders ?? 0;
    var totalReviews = ViewBag.Stats?.TotalReviews ?? 0;
}

<div class="admin-container">
    <div class="container">
        <h1 class="admin-title">
            <i class="bi bi-shield-lock"></i> Admin Dashboard
        </h1>
        <p class="admin-subtitle">Manage users, books, and site content</p>

        <div class="stats-grid">
            <div class="stat-card">
                <i class="bi bi-people-fill"></i>
                <h3>@totalUsers</h3>
                <p>Registered Users</p>
            </div>
            <div class="stat-card">
                <i class="bi bi-book-fill"></i>
                <h3>@totalBooks</h3>
                <p>Books in Catalog</p>
            </div>
            <div class="stat-card">
                <i class="bi bi-cart-fill"></i>
                <h3>@totalOrders</h3>
                <p>Total Orders</p>
            </div>
            <div class="stat-card">
                <i class="bi bi-chat-right-text-fill"></i>
                <h3>@totalReviews</h3>
                <p>Reviews</p>
            </div>
        </div>

        <div class="admin-actions">
            <a asp-action="ManageUsers" class="admin-btn">
                <i class="bi bi-people"></i> Manage Users
            </a>
            <a asp-action="ManageBooks" class="admin-btn">
                <i class="bi bi-journal-bookmark-fill"></i> Manage Books
            </a>
            <a asp-action="SimulateError" class="admin-btn admin-btn-danger">
                <i class="bi bi-exclamation-triangle"></i> Test 500 Error (Demo)
            </a>
        </div>

        <div class="admin-note">
            <i class="bi bi-info-circle"></i>
            <span>This area is restricted to administrators only.</span>
        </div>
    </div>
</div>

<style>
    .admin-container {
        min-height: 70vh;
        padding: 2rem 0;
    }

    .admin-title {
        color: #ff8c42;
        font-size: 2.2rem;
        margin-bottom: 0.5rem;
    }

    .admin-subtitle {
        color: #b0b0b0;
        margin-bottom: 2rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .stat-card {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 1.5rem;
        text-align: center;
    }

        .stat-card i {
            font-size: 2rem;
            color: #ff8c42;
            margin-bottom: 0.5rem;
        }

        .stat-card h3 {
            color: #fff;
            font-size: 2rem;
            margin: 0;
        }

        .stat-card p {
            color: #b0b0b0;
            margin: 0;
        }

    .admin-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }

    .admin-btn {
        background: #2a2a3a;
        border: 1px solid #ff8c42;
        color: #ff8c42;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .admin-btn:hover {
            background: #ff8c42;
            color: #1e1e2e;
        }

    .admin-btn-danger {
        border-color: #dc3545;
        color: #dc3545;
    }

        .admin-btn-danger:hover {
            background: #dc3545;
            color: #fff;
        }

    .admin-note {
        color: #b0b0b0;
        background: rgba(255,140,66,0.1);
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>