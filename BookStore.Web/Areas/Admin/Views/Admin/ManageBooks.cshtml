@using BookStore.Data.Models
@model List<Book>
@{
    ViewData["Title"] = "Manage Books";
}

<div class="admin-container">
    <div class="container">
        <div class="admin-header">
            <h1><i class="bi bi-journal-bookmark-fill"></i> Manage Books</h1>
            <a asp-action="Index" class="back-link"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <div class="books-table-wrapper">
            <table class="books-table">
                <thead>
                    <tr>
                        <th>Cover</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Added By</th>
                        <th>Added Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>
                                <img src="@book.CoverImageUrl" alt="@book.Title" class="book-thumb"
                                     onerror="this.src='/images/default-cover.jpg'">
                            </td>
                            <td>@book.Title</td>
                            <td>@book.Author</td>
                            <td>@book.UploadedBy?.DisplayName</td>
                            <td>@book.AddedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-area="" asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" target="_blank" class="btn-icon">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form asp-action="DeleteBook" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@book.Id" />
                                        <button type="submit" class="btn-icon btn-danger"
                                                onclick="return confirm('Delete \" @book.Title\"? This cannot be undone.')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .admin-container {
        min-height: 70vh;
        padding: 2rem 0;
    }

    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

        .admin-header h1 {
            color: #ff8c42;
            margin: 0;
        }

    .back-link {
        color: #ff8c42;
        text-decoration: none;
    }

        .back-link:hover {
            text-decoration: underline;
        }

    .alert {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
    }

    .alert-success {
        background: rgba(40, 167, 69, 0.2);
        border: 1px solid #28a745;
        color: #28a745;
    }

    .books-table-wrapper {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 1.5rem;
    }

    .books-table {
        width: 100%;
        border-collapse: collapse;
        color: #e0e0e0;
    }

        .books-table th {
            text-align: left;
            padding: 0.75rem 0.5rem;
            border-bottom: 1px solid #3a3a4a;
            color: #ff8c42;
        }

        .books-table td {
            padding: 0.75rem 0.5rem;
            border-bottom: 1px solid #2a2a3a;
        }

    .book-thumb {
        width: 50px;
        height: 70px;
        object-fit: cover;
        border-radius: 0.25rem;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .inline-form {
        display: inline;
    }

    .btn-icon {
        background: none;
        border: 1px solid #ff8c42;
        color: #ff8c42;
        width: 32px;
        height: 32px;
        border-radius: 0.25rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

        .btn-icon:hover {
            background: #ff8c42;
            color: #1e1e2e;
        }

        .btn-icon.btn-danger {
            border-color: #dc3545;
            color: #dc3545;
        }

            .btn-icon.btn-danger:hover {
                background: #dc3545;
                color: #fff;
            }
</style>