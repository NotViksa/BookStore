@page
@model BookStore.Web.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container">
    <div class="container">
        <div class="auth-card">
            <div class="auth-header">
                <i class="bi bi-person-plus auth-icon"></i>
                <h1 class="auth-title">Join BookStore</h1>
                <p class="auth-subtitle">Create your free account</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="form-group">
                    <label asp-for="Input.DisplayName" class="form-label">Display name</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="Input.DisplayName" class="form-control" autocomplete="username" placeholder="How should we call you?" />
                    </div>
                    <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Email" class="form-label">Email address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="you@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Create a strong password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Confirm password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-check-circle"></i></span>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Type your password again" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit">Register</button>
            </form>

            <div class="auth-footer">
                <p>
                    Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Same styles as login page – reuse */
    .auth-container {
        background: #0f0f1a;
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 2rem 0;
    }

    .auth-card {
        max-width: 480px;
        margin: 0 auto;
        background: #1e1e2e;
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-icon {
        font-size: 3rem;
        color: #ff8c42;
        margin-bottom: 1rem;
    }

    .auth-title {
        font-size: 2rem;
        font-weight: 700;
        color: #ff8c42;
        margin-bottom: 0.5rem;
    }

    .auth-subtitle {
        color: #b0b0b0;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: #e0e0e0;
        font-weight: 500;
    }

    .input-group {
        display: flex;
        background: #2a2a3a;
        border-radius: 0.75rem;
        overflow: hidden;
    }

    .input-group-text {
        background: #2a2a3a;
        border: none;
        color: #ff8c42;
        padding: 0.75rem;
    }

    .form-control {
        background: #2a2a3a;
        border: none;
        color: #e0e0e0;
        padding: 0.75rem;
        flex: 1;
    }

        .form-control:focus {
            outline: none;
            background: #353545;
        }

    .btn-submit {
        width: 100%;
        background: #ff8c42;
        color: #1e1e2e;
        border: none;
        border-radius: 2rem;
        padding: 0.75rem;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 0.5rem;
    }

        .btn-submit:hover {
            background: #ff9c5a;
            transform: translateY(-2px);
        }

    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        color: #b0b0b0;
    }

        .auth-footer a {
            color: #ff8c42;
            text-decoration: none;
        }

            .auth-footer a:hover {
                text-decoration: underline;
            }

    .text-danger {
        font-size: 0.8rem;
        margin-top: 0.25rem;
        display: block;
    }

    .alert {
        padding: 0.75rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
    }

    .alert-danger {
        background: rgba(220,53,69,0.1);
        border: 1px solid #dc3545;
        color: #dc3545;
    }

    .form-control {
        color: #fff !important;
        background-color: #2a2a3a !important;
        border: 1px solid #3a3a4a !important;
    }

        .form-control:focus {
            border-color: #ff8c42 !important;
            box-shadow: none !important;
        }

    .form-label {
        color: #e0e0e0 !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}