@using BookStore.Web.Controllers
@model PaginatedList<BookStore.Data.Models.Book>
@{
    ViewData["Title"] = "My Wishlist";
}

<style>
    .wishlist-container {
        background: #0f0f1a;
        min-height: 100vh;
    }

    .page-header {
        margin-bottom: 2rem;
    }

    .page-title {
        color: #ff8c42;
        font-size: 2rem;
    }

    .wishlist-items {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .wishlist-item {
        background: #1e1e2e;
        border-radius: 0.75rem;
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: background 0.2s;
    }

        .wishlist-item:hover {
            background: #2a2a3a;
        }

    .wishlist-link {
        display: flex;
        gap: 1rem;
        text-decoration: none;
        flex: 1;
    }

    .wishlist-cover img {
        width: 80px;
        height: 100px;
        object-fit: cover;
        border-radius: 0.25rem;
    }

    .wishlist-info h3 {
        color: #ff8c42;
        font-size: 1.1rem;
        margin-bottom: 0.25rem;
    }

    .wishlist-info p {
        color: #b0b0b0;
        margin-bottom: 0.5rem;
    }

    .wishlist-meta {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .price {
        color: #fff;
        font-weight: bold;
    }

    .rating {
        color: #ff8c42;
        font-size: 0.85rem;
    }

    .book-genres {
        display: flex;
        gap: 0.25rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .genre-tag {
        background: rgba(255,140,66,0.1);
        color: #ff8c42;
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
    }

    .btn-remove {
        background: rgba(220,53,69,0.1);
        border: 1px solid #dc3545;
        color: #dc3545;
        border-radius: 0.5rem;
        padding: 0.5rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-remove:hover {
            background: #dc3545;
            color: #fff;
        }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-page {
        background: #1e1e2e;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        color: #ff8c42;
        text-decoration: none;
    }

        .btn-page.disabled {
            opacity: 0.5;
            pointer-events: none;
        }

    .empty-state {
        text-align: center;
        padding: 3rem;
        background: #1e1e2e;
        border-radius: 1rem;
    }
</style>

<div class="wishlist-container">
    <div class="container">
        <div class="page-header">
            <h1 class="page-title">My Wishlist</h1>
            <p>Books you want to read</p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-bookmark" style="font-size: 3rem; color: #ff8c42;"></i>
                <h4>No books in wishlist</h4>
                <p>Start adding books you want to read!</p>
                <a asp-controller="Book" asp-action="Index" class="btn-primary" style="background:#ff8c42; color:#1e1e2e; padding:0.5rem 1rem; border-radius:0.5rem; text-decoration:none;">
                    <i class="bi bi-search"></i> Browse Books
                </a>
            </div>
        }
        else
        {
            <div class="wishlist-items">
                @foreach (var book in Model)
                {
                    <div class="wishlist-item">
                        <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" class="wishlist-link">
                            <div class="wishlist-cover">
                                <img src="@book.CoverImageUrl" alt="@book.Title" onerror="this.src='/images/default-cover.jpg'">
                            </div>
                            <div class="wishlist-info">
                                <h3>@book.Title</h3>
                                <p>by @book.Author</p>
                                <div class="wishlist-meta">
                                    <span class="price">$@book.Price.ToString("0.00")</span>
                                    <span class="rating">
                                        <i class="bi bi-star-fill"></i> @book.AverageRating.ToString("0.0")
                                    </span>
                                </div>
                                <div class="book-genres">
                                    @foreach (var genre in book.Genres.Take(3))
                                    {
                                        <span class="genre-tag">@genre.Name</span>
                                    }
                                </div>
                            </div>
                        </a>
                        <form asp-controller="Book" asp-action="ToggleWishlist" asp-route-bookId="@book.Id" method="post" class="remove-wishlist-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-remove" onclick="return confirm('Remove from wishlist?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>

            <div class="pagination">
                <a asp-action="Wishlist" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn-page @(!Model.HasPreviousPage ? "disabled" : "")">Previous</a>
                <span class="page-info" style="color:#b0b0b0;">Page @Model.PageIndex of @Model.TotalPages</span>
                <a asp-action="Wishlist" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn-page @(!Model.HasNextPage ? "disabled" : "")">Next</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.remove-wishlist-form').submit(function(e) {
                e.preventDefault();
                var form = $(this);
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function(data) {
                        if (data.success) {
                            location.reload();
                        }
                    }
                });
            });
        });
    </script>
}