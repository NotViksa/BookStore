@using BookStore.Data.Models
@using BookStore.Web.Controllers
@model PaginatedList<BookStore.Data.Models.Book>


@{
    ViewData["Title"] = "Browse Books";
}

<div class="browse-container">
    <div class="container">
        <div class="browse-header">
            <h1 class="page-title">
                <i class="bi bi-grid-3x3-gap-fill"></i> Browse Books
            </h1>
            <p class="page-subtitle">Explore our collection</p>
        </div>

        <div class="browse-card">
            <!-- Two‑column layout: filters (left) + books (right) -->
            <div class="browse-layout">
                <!-- LEFT COLUMN – FILTERS -->
                <aside class="filters-sidebar">
                    <div class="filter-group">
                        <label><i class="bi bi-tag"></i> Genre</label>
                        <select id="genreFilter" class="filter-control">
                            <option value="">All genres</option>
                            @foreach (var genre in (IEnumerable<Genre>)(ViewBag.PopularGenres ?? new List<Genre>()))
                            {
                                <option value="@genre.Name" selected="@(ViewBag.CurrentGenre == genre.Name)">@genre.Name</option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label><i class="bi bi-currency-dollar"></i> Price range</label>
                        <div class="price-range">
                            <input type="number" id="minPrice" class="filter-control" placeholder="Min $" value="@ViewBag.MinPrice">
                            <span>—</span>
                            <input type="number" id="maxPrice" class="filter-control" placeholder="Max $" value="@ViewBag.MaxPrice">
                        </div>
                    </div>

                    <button id="applyFilters" class="btn-filter-apply">
                        <i class="bi bi-funnel"></i> Apply filters
                    </button>
                    <button id="clearFilters" class="btn-filter-clear">
                        Clear all
                    </button>
                </aside>

                <!-- RIGHT COLUMN – BOOKS & PAGINATION -->
                <div class="books-main">
                    <!-- Search bar -->
                    <div class="search-bar">
                        <form asp-action="Search" method="get" class="search-form">
                            <div class="search-wrapper">
                                <i class="bi bi-search search-icon"></i>
                                <input type="text" name="query" class="search-input" placeholder="Search by title, author, or genre..." value="@ViewBag.SearchQuery">
                            </div>
                            <button type="submit" class="btn-search">Search</button>
                        </form>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-action="AddBook" class="btn-add-book">
                                <i class="bi bi-plus-circle"></i> Add Book
                            </a>
                        }
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-emoji-frown"></i>
                            <h3>No books found</h3>
                            <p>Try adjusting your filters or add a new book.</p>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-action="AddBook" class="btn-add-book">Add a Book</a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="books-grid">
                            @foreach (var book in Model)
                            {
                                var avgRating = book.Reviews != null && book.Reviews.Any()
                                ? book.Reviews.Average(r => r.Rating)
                                : 0;
                                var reviewCount = book.Reviews?.Count ?? 0;

                                <div class="book-card">
                                    <a asp-action="Details" asp-route-id="@book.Id" class="book-link">
                                        <div class="book-cover">
                                            <img src="@book.CoverImageUrl" alt="@book.Title" onerror="this.src='/images/default-cover.jpg'">
                                        </div>
                                        <div class="book-info">
                                            <h3 class="book-title">@book.Title</h3>
                                            <p class="book-author">by @book.Author</p>
                                            <div class="book-meta">
                                                <span class="price">$@book.Price.ToString("0.00")</span>
                                                <div class="rating">
                                                    <div class="stars">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            if (i <= Math.Floor(avgRating))
                                                            {
                                                                <i class="bi bi-star-fill"></i>
                                                            }
                                                            else if (i == Math.Ceiling(avgRating) && avgRating % 1 != 0)
                                                            {
                                                                <i class="bi bi-star-half"></i>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-star"></i>
                                                            }
                                                        }
                                                    </div>
                                                    <span>(@reviewCount)</span>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>

                        <!-- Pagination -->
                        <div class="pagination">
                            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn-page @(!Model.HasPreviousPage ? "disabled" : "")"><i class="bi bi-chevron-left"></i> Previous</a>
                            <span class="page-info">Page @Model.PageIndex of @Model.TotalPages</span>
                            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn-page @(!Model.HasNextPage ? "disabled" : "")">Next <i class="bi bi-chevron-right"></i></a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .browse-container {
        min-height: 70vh;
        padding-bottom: 2rem;
    }

    .browse-header {
        margin-bottom: 1.5rem;
    }

    .page-title {
        font-size: 2rem;
        color: #ff8c42;
        margin-bottom: 0.25rem;
    }

    .page-subtitle {
        color: #b0b0b0;
    }

    .browse-card {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .browse-layout {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .filters-sidebar {
        flex: 0 0 260px;
        background: #2a2a3a;
        border-radius: 1rem;
        padding: 1.5rem;
    }

    .filter-group {
        margin-bottom: 1.5rem;
    }

        .filter-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: #ff8c42;
            font-weight: 500;
        }

    .filter-control, .price-range input {
        width: 100%;
        background: #1e1e2e;
        border: 1px solid #3a3a4a;
        border-radius: 0.5rem;
        padding: 0.6rem;
        color: #e0e0e0;
    }

    .price-range {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

        .price-range span {
            color: #b0b0b0;
        }

    .btn-filter-apply, .btn-filter-clear {
        width: 100%;
        padding: 0.6rem;
        border-radius: 2rem;
        font-weight: 600;
        cursor: pointer;
        margin-bottom: 0.75rem;
        border: none;
    }

    .btn-filter-apply {
        background: #ff8c42;
        color: #1e1e2e;
    }

    .btn-filter-clear {
        background: transparent;
        border: 1px solid #ff8c42;
        color: #ff8c42;
    }

    .books-main {
        flex: 1;
        min-width: 250px;
    }

    .search-bar {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .search-form {
        display: flex;
        gap: 0.5rem;
        flex: 1;
    }

    .search-wrapper {
        position: relative;
        flex: 1;
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #b0b0b0;
    }

    .search-input {
        width: 100%;
        padding: 0.6rem 1rem 0.6rem 2.5rem;
        background: #2a2a3a;
        border: 1px solid #3a3a4a;
        border-radius: 2rem;
        color: #e0e0e0;
    }

    .btn-search, .btn-add-book {
        background: #ff8c42;
        border: none;
        padding: 0.6rem 1.2rem;
        border-radius: 2rem;
        color: #1e1e2e;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .book-card {
        background: #2a2a3a;
        border-radius: 0.75rem;
        overflow: hidden;
        transition: transform 0.2s;
    }

        .book-card:hover {
            transform: translateY(-3px);
        }

    .book-link {
        text-decoration: none;
    }

    .book-cover img {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
    }

    .book-info {
        padding: 0.75rem;
    }

    .book-title {
        font-size: 1rem;
        color: #ff8c42;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 0.25rem;
    }

    .book-author {
        font-size: 0.85rem;
        color: #b0b0b0;
    }

    .book-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.5rem;
    }

    .price {
        color: #fff;
        font-weight: bold;
    }

    .rating {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.8rem;
        color: #b0b0b0;
    }

    .stars i {
        color: #ff8c42;
        font-size: 0.7rem;
    }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 1rem;
        align-items: center;
        margin-top: 1rem;
    }

    .btn-page {
        background: #2a2a3a;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        color: #ff8c42;
        text-decoration: none;
    }

        .btn-page.disabled {
            opacity: 0.5;
            pointer-events: none;
        }

    .empty-state {
        text-align: center;
        padding: 3rem;
        background: #2a2a3a;
        border-radius: 1rem;
    }

    @@media (max-width: 768px) {
        .browse-layout {
            flex-direction: column;
        }

        .filters-sidebar {
            width: 100%;
        }

        .search-bar {
            flex-direction: column;
        }
    }
</style>

<script>
    document.getElementById('applyFilters')?.addEventListener('click', function() {
        const genre = document.getElementById('genreFilter').value;
        const minPrice = document.getElementById('minPrice').value;
        const maxPrice = document.getElementById('maxPrice').value;
        let url = '@Url.Action("Index")?';
        if (genre) url += '&genre=' + encodeURIComponent(genre);
        if (minPrice) url += '&minPrice=' + minPrice;
        if (maxPrice) url += '&maxPrice=' + maxPrice;
        window.location.href = url;
    });
    document.getElementById('clearFilters')?.addEventListener('click', function() {
        window.location.href = '@Url.Action("Index")';
    });
</script>