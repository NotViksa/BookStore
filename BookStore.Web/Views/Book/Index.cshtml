@using BookStore.Data.Models
@using BookStore.Web.Controllers
@model PaginatedList<BookStore.Data.Models.Book>

@{
    ViewData["Title"] = "Browse Books";
}

<div class="browse-container">
    <div class="container">
        <!-- Header -->
        <div class="browse-header">
            <h1 class="page-title">Browse Books</h1>
            <div class="search-filter">
                <form asp-action="Search" method="get" class="search-form">
                    <input type="text" name="query" class="search-input" placeholder="Search by title, author, genre..." value="@ViewBag.SearchQuery">
                    <button type="submit" class="search-btn"><i class="bi bi-search"></i></button>
                </form>
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-action="AddBook" class="btn-add"><i class="bi bi-plus-circle"></i> Add Book</a>
                }
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
            <select id="genreFilter" class="filter-select">
                <option value="">All Genres</option>
                @foreach (var genre in ViewBag.PopularGenres ?? new List<Genre>())
                {
                    <option value="@genre.Name" selected="@(ViewBag.CurrentGenre == genre.Name)">@genre.Name</option>
                }
            </select>
            <input type="number" id="minPrice" class="price-input" placeholder="Min price" value="@ViewBag.MinPrice">
            <span>-</span>
            <input type="number" id="maxPrice" class="price-input" placeholder="Max price" value="@ViewBag.MaxPrice">
            <button id="applyFilters" class="btn-filter">Apply</button>
        </div>

        <!-- Books Grid -->
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-book"></i>
                <h3>No books found</h3>
                <p>Try adjusting your filters or add a new book.</p>
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-action="AddBook" class="btn-add">Add a Book</a>
                }
            </div>
        }
        else
        {
            <div class="books-grid">
                @foreach (var book in Model)
                {
                    <div class="book-card">
                        <a asp-action="Details" asp-route-id="@book.Id" class="book-link">
                            <div class="book-cover">
                                <img src="@book.CoverImageUrl" alt="@book.Title" onerror="this.src='/images/default-cover.jpg'">
                            </div>
                            <div class="book-info">
                                <h3 class="book-title">@book.Title</h3>
                                <p class="book-author">by @book.Author</p>
                                <div class="book-price">$@book.Price.ToString("0.00")</div>
                                <div class="book-rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= Math.Round(book.AverageRating))
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    }
                                    <span>(@book.RatingCount)</span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>

            <!-- Pagination -->
            <div class="pagination">
                <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn-page @(!Model.HasPreviousPage ? "disabled" : "")">Previous</a>
                <span class="page-info">Page @Model.PageIndex of @Model.TotalPages</span>
                <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn-page @(!Model.HasNextPage ? "disabled" : "")">Next</a>
            </div>
        }
    </div>
</div>

<style>
    .browse-container {
        background: #0f0f1a;
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-title {
        font-size: 2rem;
        color: #ff8c42;
        margin-bottom: 1rem;
    }

    .browse-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .search-form {
        display: flex;
        gap: 0.5rem;
    }

    .search-input {
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        border: none;
        background: #1e1e2e;
        color: #e0e0e0;
        width: 250px;
    }

    .search-btn, .btn-add, .btn-filter {
        background: #ff8c42;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        color: #1e1e2e;
        cursor: pointer;
    }

    .filters-bar {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .filter-select, .price-input {
        background: #1e1e2e;
        border: none;
        padding: 0.5rem;
        border-radius: 0.5rem;
        color: #e0e0e0;
    }

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.5rem;
    }

    .book-card {
        background: #1e1e2e;
        border-radius: 0.75rem;
        overflow: hidden;
        transition: transform 0.2s;
    }

        .book-card:hover {
            transform: translateY(-5px);
        }

    .book-link {
        text-decoration: none;
        display: block;
    }

    .book-cover img {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
    }

    .book-info {
        padding: 0.75rem;
    }

    .book-title {
        font-size: 1rem;
        color: #ff8c42;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .book-author {
        font-size: 0.85rem;
        color: #b0b0b0;
    }

    .book-price {
        font-weight: bold;
        color: #fff;
    }

    .book-rating i {
        color: #ff8c42;
        font-size: 0.8rem;
    }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 1rem;
        margin-top: 2rem;
    }

    .btn-page {
        background: #1e1e2e;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        color: #ff8c42;
        text-decoration: none;
    }

        .btn-page.disabled {
            opacity: 0.5;
            pointer-events: none;
        }

    .empty-state {
        text-align: center;
        padding: 3rem;
        background: #1e1e2e;
        border-radius: 1rem;
    }
</style>

<script>
    document.getElementById('applyFilters')?.addEventListener('click', function() {
        const genre = document.getElementById('genreFilter').value;
        const minPrice = document.getElementById('minPrice').value;
        const maxPrice = document.getElementById('maxPrice').value;
        let url = '@Url.Action("Index")?';
        if (genre) url += '&genre=' + encodeURIComponent(genre);
        if (minPrice) url += '&minPrice=' + minPrice;
        if (maxPrice) url += '&maxPrice=' + maxPrice;
        window.location.href = url;
    });
</script>