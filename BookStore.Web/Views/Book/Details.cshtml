@using System.Security.Claims
@model BookStore.Web.Models.BookDetailsViewModel
@{
    var reviewAverage = Model.Reviews.Any() ? Model.Reviews.Average(r => r.Rating) : 0;
    var totalReviews = Model.Reviews.Count();

}

@{
    ViewData["Title"] = Model.Book.Title;
}

<div class="book-details-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="book-hero">
        <div class="container">
            <div class="book-hero-content">
                <div class="book-cover-large">
                    <img src="@Model.Book.CoverImageUrl" alt="@Model.Book.Title" onerror="this.src='/images/default-cover.jpg'">
                </div>
                <div class="book-info-large">
                    <div class="book-metadata">
                        <span class="book-genre">
                            @foreach (var genre in Model.Book.Genres.Take(2))
                            {
                                <a asp-controller="Book" asp-action="Index" asp-route-genre="@genre.Name">@genre.Name</a>
                                if (genre != Model.Book.Genres.Last())
                                {
                                    <span>, </span>
                                }
                            }
                        </span>
                    </div>

                    <h1 class="book-title-large">@Model.Book.Title</h1>
                    <p class="book-author-large">by <a asp-controller="Book" asp-action="ByAuthor" asp-route-author="@Model.Book.Author">@Model.Book.Author</a></p>

                    <div class="book-rating-large">
                        <div class="stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= Math.Floor(reviewAverage))
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                                else if (i == Math.Ceiling(reviewAverage) && reviewAverage % 1 != 0)
                                {
                                    <i class="bi bi-star-half"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star"></i>
                                }
                            }
                        </div>
                        <span class="rating-value">@reviewAverage.ToString("0.0")</span>
                        <span class="rating-count">(@totalReviews reviews)</span>
                    </div>

                    <div class="book-price-large">
                        <span class="price">$@Model.Book.Price.ToString("0.00")</span>
                    </div>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="book-actions">
                            <!--Add to Cart Button-->
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="add-to-cart-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                                <button type="submit" class="btn-add-to-cart">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </button>
                            </form>
                            <!-- Wishlist Button -->
                            <form asp-action="ToggleWishlist" asp-route-bookId="@Model.Book.Id" method="post" class="wishlist-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-wishlist @(ViewBag.IsInWishlist ? "in-wishlist" : "")">
                                    <i class="bi @(ViewBag.IsInWishlist ? "bi-bookmark-fill" : "bi-bookmark-plus")"></i>
                                    @(ViewBag.IsInWishlist ? "In Wishlist" : "Add to Wishlist")
                                </button>
                            </form>
                        </div>
                    }

                    @if (Model.Book.UploadedById == User.FindFirstValue(ClaimTypes.NameIdentifier) || User.IsInRole("Administrator"))
                    {
                        <form asp-action="Delete" method="post" class="delete-form mt-3">
                            <input type="hidden" name="id" value="@Model.Book.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-delete"
                                    onclick="return confirm('Are you sure you want to delete this book?')">
                                <i class="bi bi-trash"></i> Delete Book
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="book-details-content">
            <div class="book-details-left">
                <section class="book-section">
                    <h2 class="section-title">About the Book</h2>
                    <div class="book-description">
                        @Model.Book.Description
                    </div>

                    <div class="book-details-grid">
                        <div class="detail-item">
                            <span class="detail-label">ISBN:</span>
                            <span class="detail-value">@Model.Book.ISBN</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Publisher:</span>
                            <span class="detail-value">@(Model.Book.Publisher ?? "Unknown")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Publication Year:</span>
                            <span class="detail-value">@(Model.Book.PublicationYear?.ToString() ?? "Unknown")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Pages:</span>
                            <span class="detail-value">@(Model.Book.PageCount?.ToString() ?? "Unknown")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Added by:</span>
                            <span class="detail-value">@(Model.Book.UploadedBy?.DisplayName ?? "Unknown")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Added on:</span>
                            <span class="detail-value">@Model.Book.AddedDate.ToString("MMMM dd, yyyy")</span>
                        </div>
                    </div>
                </section>

                <section class="book-section" id="reviews">
                    <h2 class="section-title">Reviews</h2>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="add-review">
                            <h3>Write a Review</h3>
                            <form asp-controller="Review" asp-action="AddReview" method="post" class="review-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="BookId" value="@Model.Book.Id" />

                                <div class="review-rating">
                                    <span class="rating-label">Your Rating:</span>
                                    <div class="review-star-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi bi-star @(i == 1 ? "selected" : "")" data-rating="@i"></i>
                                        }
                                    </div>
                                    <input type="hidden" name="Rating" id="selected-rating" value="1" />
                                </div>

                                <div class="form-group">
                                    <textarea name="Content" class="form-control" rows="4"
                                          placeholder="Share your thoughts about this book..." required></textarea>
                                </div>

                                <button type="submit" class="btn-submit-review">
                                    <i class="bi bi-chat-right-text"></i> Post Review
                                </button>
                            </form>
                        </div>
                    }

                    <div class="reviews-list">
                        @if (!Model.Reviews.Any())
                        {
                            <div class="no-reviews">
                                <i class="bi bi-chat"></i>
                                <p>No reviews yet. Be the first to review this book!</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var review in Model.Reviews)
                            {
                                <div class="review-card" data-review-id="@review.Id">
                                    <div class="review-header">
                                        <img src="@review.PostedBy?.ProfileImageUrl" class="reviewer-avatar" alt="@review.PostedBy?.DisplayName">
                                        <div class="reviewer-info">
                                            <strong>@review.PostedBy?.DisplayName</strong>
                                            <span class="review-date">@review.PostedDate.ToString("MMMM dd, yyyy")</span>
                                        </div>
                                        <div class="review-rating-display">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <div class="review-content">
                                        <p>@review.Content</p>
                                    </div>

                                    @if (User.Identity.IsAuthenticated &&
                                                                (review.PostedById == User.FindFirstValue(ClaimTypes.NameIdentifier) || User.IsInRole("Administrator")))
                                    {
                                        <div class="review-actions">
                                            @if (review.PostedById == User.FindFirstValue(ClaimTypes.NameIdentifier))
                                            {
                                                <button class="btn-edit-review" data-review-id="@review.Id">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </button>
                                            }
                                            <form asp-controller="Review" asp-action="DeleteReview" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="reviewId" value="@review.Id" />
                                                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                                                <button type="submit" class="btn-delete-review"
                                                        onclick="return confirm('Delete this review?')">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>

                                        <!-- Edit Review Form (hidden) -->
                                        <div class="edit-review-form" style="display: none;" data-review-id="@review.Id">
                                            <form asp-controller="Review" asp-action="EditReview" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="ReviewId" value="@review.Id" />
                                                <input type="hidden" name="BookId" value="@Model.Book.Id" />

                                                <div class="edit-rating">
                                                    <span class="rating-label">Rating:</span>
                                                    <div class="edit-star-rating" data-review-id="@review.Id">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            <i class="bi bi-star @(i <= review.Rating ? "rated" : "")" data-rating="@i"></i>
                                                        }
                                                    </div>
                                                    <input type="hidden" name="Rating" class="edit-rating-value" value="@review.Rating" />
                                                </div>

                                                <div class="form-group">
                                                    <textarea name="Content" class="form-control" rows="3">@review.Content</textarea>
                                                </div>

                                                <div class="edit-actions">
                                                    <button type="submit" class="btn-save-edit">Save Changes</button>
                                                    <button type="button" class="btn-cancel-edit">Cancel</button>
                                                </div>
                                            </form>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </section>
            </div>

            <!-- Right Column - Similar Books -->
            <div class="book-details-right">
                @if (Model.SimilarBooks != null && Model.SimilarBooks.Any())
                {
                    <section class="similar-books">
                        <h3 class="sidebar-title">Similar Books</h3>
                        <div class="similar-books-list">
                            @foreach (var similar in Model.SimilarBooks.Take(5))
                            {
                                <a asp-controller="Book" asp-action="Details" asp-route-id="@similar.Id" class="similar-book-item">
                                    <div class="similar-book-cover">
                                        <img src="@similar.CoverImageUrl" alt="@similar.Title" onerror="this.src='/images/default-cover.jpg'">
                                    </div>
                                    <div class="similar-book-info">
                                        <h4>@similar.Title</h4>
                                        <p>@similar.Author</p>
                                        <div class="similar-book-rating">
                                            <i class="bi bi-star-fill"></i>
                                            <span>@similar.AverageRating.ToString("0.0")</span>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </section>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Wishlist toggle with AJAX
            $('.wishlist-form').submit(function(e) {
                e.preventDefault();
                var form = $(this);
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function(data) {
                        if (data.success) {
                            var btn = form.find('button');
                            btn.toggleClass('in-wishlist');
                            if (btn.hasClass('in-wishlist')) {
                                btn.html('<i class="bi bi-bookmark-fill"></i> In Wishlist');
                            } else {
                                btn.html('<i class="bi bi-bookmark-plus"></i> Add to Wishlist');
                            }
                        }
                    }
                });
            });

            // Book rating (star rating control for the book itself)
            $('.star-rating i').hover(
                function() {
                    var rating = $(this).data('rating');
                    $(this).parent().find('i').each(function(index) {
                        if (index < rating) $(this).addClass('hover');
                    });
                },
                function() {
                    $(this).parent().find('i').removeClass('hover');
                }
            );
            $('.star-rating i').click(function() {
                var rating = $(this).data('rating');
                var bookId = $(this).parent().data('book-id');
                $.ajax({
                    url: '/Book/SubmitRating',
                    type: 'POST',
                    data: {
                        bookId: bookId,
                        ratingValue: rating,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(data) {
                        if (data.success) location.reload();
                        else alert('Failed to submit rating.');
                    },
                    error: function() {
                        alert('An error occurred.');
                    }
                });
            });

            // ========== REVIEW STAR RATING (for adding a new review) ==========
            // Pre-select 1 star on page load
            $('#selected-rating').val(1);
            $('.review-star-rating i').hover(
                function() {
                    var rating = $(this).data('rating');
                    $(this).parent().find('i').each(function(index) {
                        if (index < rating) $(this).addClass('hover');
                    });
                },
                function() {
                    $(this).parent().find('i').removeClass('hover');
                }
            );
            $('.review-star-rating i').click(function() {
                var rating = $(this).data('rating');
                var parent = $(this).parent();
                parent.find('i').removeClass('selected');
                parent.find('i').each(function(index) {
                    if (index < rating) $(this).addClass('selected');
                });
                $('#selected-rating').val(rating);
            });

            // Validate review form before submission
            $('.review-form').submit(function(e) {
                var rating = $('#selected-rating').val();
                var content = $('textarea[name="Content"]').val().trim();
                if (!rating || rating < 1 || rating > 5) {
                    alert('Please select a rating (1-5 stars).');
                    e.preventDefault();
                    return false;
                }
                if (content.length < 10) {
                    alert('Please write at least 10 characters for your review.');
                    e.preventDefault();
                    return false;
                }
                return true;
            });

            $('.btn-edit-review').click(function() {
                var reviewCard = $(this).closest('.review-card');
                reviewCard.find('.review-content').hide();
                reviewCard.find('.review-actions').hide();
                reviewCard.find('.edit-review-form').show();
            });

            $('.btn-cancel-edit').click(function() {
                var editForm = $(this).closest('.edit-review-form');
                var reviewCard = editForm.closest('.review-card');
                editForm.hide();
                reviewCard.find('.review-content').show();
                reviewCard.find('.review-actions').show();
            });

            $('.edit-star-rating i').hover(
                function() {
                    var rating = $(this).data('rating');
                    $(this).parent().find('i').each(function(index) {
                        if (index < rating) $(this).addClass('hover');
                    });
                },
                function() {
                    $(this).parent().find('i').removeClass('hover');
                }
            );
            $('.edit-star-rating i').click(function() {
                var rating = $(this).data('rating');
                var parent = $(this).parent();
                parent.find('i').removeClass('rated');
                parent.find('i').each(function(index) {
                    if (index < rating) $(this).addClass('rated');
                });
                parent.siblings('.edit-rating-value').val(rating);
            });
        });
    </script>
}

<style>
    .book-details-container {
        background: #0f0f1a;
    }

    .book-hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        padding: 3rem 0;
        margin-bottom: 2rem;
    }

    .book-hero-content {
        display: flex;
        gap: 3rem;
        flex-wrap: wrap;
        align-items: flex-start;
    }

    .book-cover-large {
        flex: 0 0 250px;
    }

        .book-cover-large img {
            width: 100%;
            border-radius: 1rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

    .book-info-large {
        flex: 1;
        min-width: 250px;
    }

    .book-title-large {
        font-size: 2.5rem;
        color: #ff8c42;
        margin-bottom: 0.5rem;
    }

    .book-author-large {
        font-size: 1.2rem;
        color: #b0b0b0;
        margin-bottom: 1rem;
    }

        .book-author-large a {
            color: #ff8c42;
            text-decoration: none;
        }

    .book-rating-large {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .stars i {
        color: #ff8c42;
    }

    .book-price-large {
        font-size: 1.8rem;
        font-weight: bold;
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .book-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .btn-wishlist, .btn-delete {
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-wishlist {
        background: rgba(255,140,66,0.1);
        border: 1px solid #ff8c42;
        color: #ff8c42;
    }

        .btn-wishlist.in-wishlist {
            background: #ff8c42;
            color: #1e1e2e;
        }

    .btn-delete {
        background: rgba(220,53,69,0.1);
        border: 1px solid #dc3545;
        color: #dc3545;
    }

    .book-details-content {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .book-details-left {
        flex: 2;
        min-width: 250px;
    }

    .book-details-right {
        flex: 1;
        min-width: 250px;
    }

    .book-section {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

    .section-title {
        color: #ff8c42;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .book-description {
        line-height: 1.6;
        color: #e0e0e0;
        margin-bottom: 1.5rem;
    }

    .book-details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px,1fr));
        gap: 0.75rem;
    }

    .detail-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .detail-label {
        color: #b0b0b0;
        font-weight: 500;
    }

    .detail-value {
        color: #ff8c42;
    }

    .add-review {
        background: #2a2a3a;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

    .review-form textarea {
        width: 100%;
        background: #1e1e2e;
        border: 1px solid #ff8c42;
        border-radius: 0.5rem;
        padding: 0.75rem;
        color: #e0e0e0;
        margin-bottom: 1rem;
    }

    .btn-submit-review {
        background: #ff8c42;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        color: #1e1e2e;
        font-weight: 600;
        cursor: pointer;
    }

    .review-card {
        background: #2a2a3a;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .review-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
    }

    .reviewer-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
    }

    .reviewer-info strong {
        color: #ff8c42;
    }

    .review-date {
        font-size: 0.75rem;
        color: #b0b0b0;
        margin-left: 0.5rem;
    }

    .review-rating-display i {
        color: #ff8c42;
    }

    .similar-books {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 1rem;
        position: sticky;
        top: 1rem;
    }

    .sidebar-title {
        color: #ff8c42;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }

    .similar-books-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .similar-book-item {
        display: flex;
        gap: 0.75rem;
        text-decoration: none;
        transition: transform 0.2s;
    }

        .similar-book-item:hover {
            transform: translateX(5px);
        }

    .similar-book-cover img {
        width: 50px;
        height: 70px;
        object-fit: cover;
        border-radius: 0.25rem;
    }

    .similar-book-info h4 {
        color: #ff8c42;
        font-size: 0.9rem;
        margin: 0 0 0.25rem;
    }

    .similar-book-info p {
        color: #b0b0b0;
        font-size: 0.8rem;
        margin: 0;
    }

    .review-star-rating i {
        cursor: pointer;
        font-size: 1.2rem;
        margin-right: 2px;
        color: #555;
        transition: color 0.2s;
    }

    .btn-add-to-cart {
        background: #28a745;
        color: #fff;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
    }

    .btn-edit-review, .btn-delete-review {
        background: rgba(255,140,66,0.1);
        border: 1px solid #ff8c42;
        color: #ff8c42;
        padding: 0.25rem 0.75rem;
        border-radius: 0.25rem;
        cursor: pointer;
        margin-right: 0.5rem;
    }

    .btn-delete-review {
        border-color: #dc3545;
        color: #dc3545;
    }

        .btn-edit-review:hover, .btn-delete-review:hover {
            background: #ff8c42;
            color: #1e1e2e;
        }

        .btn-delete-review:hover {
            background: #dc3545;
            color: #fff;
        }

        .btn-add-to-cart:hover {
            background: #218838;
        }

        .review-star-rating i.selected {
            color: #ff8c42; /* orange when selected */
        }

        .review-star-rating i.hover {
            color: #ffaa66; /* lighter orange on hover */
        }

    .btn-delete {
        background: rgba(220,53,69,0.1);
        border: 1px solid #dc3545;
        color: #dc3545;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
    }

        .btn-delete:hover {
            background: #dc3545;
            color: #fff;
        }

    @@media (max-width: 768px) {
        .book-hero-content {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .book-actions {
            justify-content: center;
        }
    }
</style>