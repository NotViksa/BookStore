@model BookStore.Web.ViewModels.AddBookViewModel
@{
    ViewData["Title"] = "Add a Book";
}

<div class="add-book-container">
    <div class="container">
        <div class="add-book-header">
            <h1 class="page-title">
                <i class="bi bi-plus-circle"></i> Add a Book to the Collection
            </h1>
            <p class="page-subtitle">Share your favorite books with the community</p>
        </div>

        <div class="add-book-card">
            <form asp-action="AddBook" enctype="multipart/form-data" class="add-book-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-columns">
                    <div class="form-left">
                        <div class="form-group">
                            <label asp-for="Title" class="form-label">
                                <i class="bi bi-book"></i> Book Title
                            </label>
                            <input asp-for="Title" class="form-control" placeholder="e.g., The Great Gatsby" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Author" class="form-label">
                                <i class="bi bi-pencil"></i> Author
                            </label>
                            <input asp-for="Author" class="form-control" placeholder="e.g., F. Scott Fitzgerald" />
                            <span asp-validation-for="Author" class="text-danger"></span>
                        </div>

                        <div class="form-row">
                            <div class="form-group half">
                                <label asp-for="ISBN" class="form-label">
                                    <i class="bi bi-upc-scan"></i> ISBN
                                </label>
                                <input asp-for="ISBN" class="form-control" placeholder="9780743273565" />
                                <span asp-validation-for="ISBN" class="text-danger"></span>
                            </div>

                            <div class="form-group half">
                                <label asp-for="Price" class="form-label">
                                    <i class="bi bi-currency-dollar"></i> Price
                                </label>
                                <input asp-for="Price" class="form-control" placeholder="12.99" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group half">
                                <label asp-for="PublicationYear" class="form-label">Publication Year</label>
                                <input asp-for="PublicationYear" class="form-control" placeholder="1925" />
                                <span asp-validation-for="PublicationYear" class="text-danger"></span>
                            </div>

                            <div class="form-group half">
                                <label asp-for="PageCount" class="form-label">Page Count</label>
                                <input asp-for="PageCount" class="form-control" placeholder="180" />
                                <span asp-validation-for="PageCount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Publisher" class="form-label">Publisher</label>
                            <input asp-for="Publisher" class="form-control" placeholder="Scribner" />
                            <span asp-validation-for="Publisher" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Genres" class="form-label">
                                <i class="bi bi-tags"></i> Genres
                            </label>
                            <input asp-for="Genres" class="form-control"
                                   placeholder="fiction, classic, romance (separate with commas)" />
                            <span asp-validation-for="Genres" class="text-danger"></span>
                            <small class="form-hint">Separate multiple genres with commas</small>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="form-label">
                                <i class="bi bi-text-paragraph"></i> Description
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="6"
                                      placeholder="Tell us about the book..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-right">
                        <div class="cover-upload-section">
                            <label class="form-label">
                                <i class="bi bi-image"></i> Book Cover
                            </label>

                            <div class="cover-upload-area" id="coverUploadArea">
                                <input asp-for="CoverImage" type="file" id="CoverImage"
                                       accept=".jpg,.jpeg,.png,.gif" style="display: none;" />

                                <div class="cover-placeholder">
                                    <i class="bi bi-cloud-upload"></i>
                                    <p>Click or drag to upload cover image</p>
                                    <small>JPG, PNG, GIF • Max 5MB</small>
                                </div>

                                <div class="cover-preview" style="display: none;">
                                    <img id="coverPreview" src="#" alt="Cover preview" />
                                    <button type="button" class="change-cover">
                                        <i class="bi bi-pencil"></i> Change
                                    </button>
                                </div>
                            </div>

                            <span asp-validation-for="CoverImage" class="text-danger"></span>
                        </div>

                        <div class="tips-box">
                            <h4><i class="bi bi-lightbulb"></i> Tips</h4>
                            <ul>
                                <li>Use the official book cover for best results</li>
                                <li>Make sure the ISBN is correct</li>
                                <li>Add relevant genres to help others find the book</li>
                                <li>Write a helpful description</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-check-circle"></i> Add Book
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            var coverUploadArea = $('#coverUploadArea');
            var coverInput = $('#CoverImage');
            var coverPlaceholder = $('.cover-placeholder');
            var coverPreview = $('.cover-preview');
            var coverPreviewImg = $('#coverPreview');

            coverUploadArea.on('click', function() {
                coverInput.click();
            });

            coverInput.on('change', function(e) {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        coverPreviewImg.attr('src', e.target.result);
                        coverPlaceholder.hide();
                        coverPreview.show();
                    };
                    reader.readAsDataURL(file);
                }
            });

            $('.change-cover').on('click', function(e) {
                e.stopPropagation();
                coverInput.val('');
                coverPreview.hide();
                coverPlaceholder.show();
            });

            coverUploadArea.on('dragover', function(e) {
                e.preventDefault();
                $(this).addClass('dragover');
            });

            coverUploadArea.on('dragleave', function(e) {
                e.preventDefault();
                $(this).removeClass('dragover');
            });

            coverUploadArea.on('drop', function(e) {
                e.preventDefault();
                $(this).removeClass('dragover');

                var files = e.originalEvent.dataTransfer.files;
                if (files.length > 0) {
                    coverInput[0].files = files;
                    coverInput.trigger('change');
                }
            });
        });
    </script>
}

<style>
    .change-cover {
        background: #ff8c42;
        color: #1e1e2e;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.75rem;
        transition: all 0.3s ease;
    }

        .change-cover:hover {
            background: #ff9c5a;
            transform: translateY(-2px);
        }

        .change-cover i {
            margin-right: 0.25rem;
        }
    .add-book-container {
        min-height: 70vh;
        padding-bottom: 2rem;
    }

    .add-book-card {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .form-columns {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .form-left, .form-right {
        flex: 1;
        min-width: 250px;
    }

    .form-group {
        margin-bottom: 1.25rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: #ff8c42;
        font-weight: 500;
    }

    .form-control {
        width: 100%;
        background: #2a2a3a;
        border: 1px solid #3a3a4a;
        border-radius: 0.5rem;
        padding: 0.75rem;
        color: #e0e0e0;
    }

        .form-control:focus {
            outline: none;
            border-color: #ff8c42;
        }

    .form-row {
        display: flex;
        gap: 1rem;
    }

        .form-row .half {
            flex: 1;
        }

    .cover-upload-area {
        background: #2a2a3a;
        border: 2px dashed #ff8c42;
        border-radius: 0.75rem;
        padding: 2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .cover-upload-area.dragover {
            background: #3a3a4a;
        }

    .cover-placeholder i, .cover-preview i {
        font-size: 3rem;
        color: #ff8c42;
    }

    .cover-preview img {
        max-width: 100%;
        max-height: 200px;
        border-radius: 0.5rem;
    }

    .tips-box {
        background: #2a2a3a;
        border-radius: 0.75rem;
        padding: 1rem;
        margin-top: 1.5rem;
    }

        .tips-box h4 {
            color: #ff8c42;
            margin-bottom: 0.5rem;
        }

        .tips-box ul {
            margin: 0;
            padding-left: 1.25rem;
        }

        .tips-box li {
            margin-bottom: 0.25rem;
            color: #b0b0b0;
        }

    .form-actions {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 140, 66, 0.2);
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
    }

    .btn-submit, .btn-cancel {
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-submit {
        background: #ff8c42;
        color: #1e1e2e;
        border: none;
    }

        .btn-submit:hover {
            background: #ff9c5a;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: transparent;
        color: #ff8c42;
        border: 1px solid #ff8c42;
    }

        .btn-cancel:hover {
            background: rgba(255, 140, 66, 0.1);
        }

    @@media (max-width: 768px) {
        .form-row {
            flex-direction: column;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-submit, .btn-cancel {
            justify-content: center;
        }
    }
</style>

<div class="add-book-container">