@{
    ViewData["Title"] = "Home - BookStore";
}

<div class="home-container">
    <div class="container">
        <!-- Hero section (card) -->
        <div class="hero-card">
            <div class="hero-content">
                <h1 class="hero-title">Discover Your Next Great Read</h1>
                <p class="hero-subtitle">Join our community of book lovers. Explore, review, and collect books you love.</p>
                <div class="hero-buttons">
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn-primary">Get Started</a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn-secondary">Sign In</a>
                    }
                    else
                    {
                        <a asp-controller="Book" asp-action="Index" class="btn-primary">Browse Books</a>
                        <a asp-controller="Book" asp-action="AddBook" class="btn-secondary">Add a Book</a>
                    }
                </div>
            </div>
        </div>

        <!-- Popular Books -->
        @if (ViewBag.PopularBooks != null && ((IEnumerable<BookStore.Data.Models.Book>)ViewBag.PopularBooks).Any())
        {
            <div class="section-card">
                <div class="section-header">
                    <h2><i class="bi bi-fire"></i> Popular Books</h2>
                    <a asp-controller="Book" asp-action="Index" class="see-all">View all <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="books-grid">
                    @foreach (var book in (IEnumerable<BookStore.Data.Models.Book>)ViewBag.PopularBooks)
                    {
                        <partial name="_BookCard" model="book" />
                    }
                </div>
            </div>
        }

        <!-- Recent Books -->
        @if (ViewBag.RecentBooks != null && ((IEnumerable<BookStore.Data.Models.Book>)ViewBag.RecentBooks).Any())
        {
            <div class="section-card">
                <div class="section-header">
                    <h2><i class="bi bi-clock-history"></i> Recently Added</h2>
                    <a asp-controller="Book" asp-action="Index" class="see-all">View all <i class="bi bi-arrow-right"></i></a>
                </div>
                <div class="books-grid">
                    @foreach (var book in (IEnumerable<BookStore.Data.Models.Book>)ViewBag.RecentBooks)
                    {
                        <partial name="_BookCard" model="book" />
                    }
                </div>
            </div>
        }

        <!-- Popular Genres -->
        @if (ViewBag.PopularGenres != null && ((IEnumerable<BookStore.Data.Models.Genre>)ViewBag.PopularGenres).Any())
        {
            var genres = (IEnumerable<BookStore.Data.Models.Genre>)ViewBag.PopularGenres;
            <div class="section-card">
                <div class="section-header">
                    <h2><i class="bi bi-tags"></i> Popular Genres</h2>
                </div>
                <div class="genres-grid">
                    @foreach (var genre in genres.Take(6))
                    {
                        <a asp-controller="Book" asp-action="Index" asp-route-genre="@genre.Name" class="genre-pill">
                            @genre.Name
                            <span class="genre-count">(@genre.BookCount)</span>
                        </a>
                    }
                </div>
            </div>
        }

        <!-- Call to Action (for non‑authenticated) -->
        @if (!User.Identity.IsAuthenticated)
        {
            <div class="cta-card">
                <div class="cta-content">
                    <h3>Join the BookStore Community</h3>
                    <p>Create an account to start adding books, writing reviews, and building your wishlist.</p>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn-primary">Sign Up Free</a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .home-container {
        min-height: 70vh;
        padding-bottom: 2rem;
    }

    .hero-card {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        border-radius: 1rem;
        padding: 3rem;
        text-align: center;
        margin-bottom: 2rem;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: #ff8c42;
        margin-bottom: 1rem;
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: #e0e0e0;
        max-width: 600px;
        margin: 0 auto 2rem;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .btn-primary, .btn-secondary {
        padding: 0.75rem 1.5rem;
        border-radius: 2rem;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-primary {
        background: #ff8c42;
        color: #1e1e2e;
    }

        .btn-primary:hover {
            background: #ff9c5a;
            transform: translateY(-2px);
        }

    .btn-secondary {
        background: transparent;
        border: 1px solid #ff8c42;
        color: #ff8c42;
    }

    .section-card {
        background: #1e1e2e;
        border-radius: 1rem;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

        .section-header h2 {
            font-size: 1.5rem;
            color: #ff8c42;
            margin: 0;
        }

    .see-all {
        color: #ff8c42;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.5rem;
    }

    .genres-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .genre-pill {
        background: #2a2a3a;
        color: #ff8c42;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.9rem;
    }

        .genre-pill:hover {
            background: #ff8c42;
            color: #1e1e2e;
        }

    .genre-count {
        font-size: 0.7rem;
        margin-left: 0.3rem;
    }

    .cta-card {
        background: linear-gradient(135deg, #ff8c42, #ff6b6b);
        border-radius: 1rem;
        padding: 2rem;
        text-align: center;
    }

    .cta-content h3 {
        font-size: 1.5rem;
        color: #1e1e2e;
        margin-bottom: 0.5rem;
    }

    .cta-content p {
        color: #1e1e2e;
        margin-bottom: 1rem;
    }

    .cta-card .btn-primary {
        background: #1e1e2e;
        color: #ff8c42;
    }

    @@media (max-width: 768px) {
        .hero-title {
            font-size: 1.8rem;
        }

        .section-card {
            padding: 1rem;
        }

        .books-grid {
            gap: 1rem;
        }
    }
</style>