@{
    ViewData["Title"] = "Server Error";
    Layout = "_Layout";
}

<div class="error-container">
    <div class="error-content">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h1 class="error-code">500</h1>
        <h2 class="error-title">Server Error</h2>
        <p class="error-message">Something went wrong on our end. Our team of bookworms is working on it!</p>
        <div class="error-actions">
            <a asp-controller="Home" asp-action="Index" class="btn-home">
                <i class="bi bi-house-door"></i> Home
            </a>
            <button onclick="window.location.reload()" class="btn-retry">
                <i class="bi bi-arrow-clockwise"></i> Try Again
            </button>
        </div>
        <div class="error-note">
            <i class="bi bi-info-circle"></i>
            <p>If the problem persists, please <a href="/Home/About">contact us</a>.</p>
        </div>
    </div>
</div>

<style>
    .error-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .error-content {
        text-align: center;
        max-width: 600px;
    }

    .error-icon {
        font-size: 5rem;
        color: #ff8c42;
        margin-bottom: 1rem;
    }

    .error-code {
        font-size: 6rem;
        font-weight: bold;
        color: #ff8c42;
        margin-bottom: 0.5rem;
    }

    .error-title {
        font-size: 2rem;
        color: #fff;
        margin-bottom: 1rem;
    }

    .error-message {
        color: #b0b0b0;
        margin-bottom: 2rem;
    }

    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .btn-home, .btn-retry {
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
        font-size: 1rem;
    }

    .btn-home {
        background: #ff8c42;
        color: #1e1e2e;
    }

        .btn-home:hover {
            background: #ff9c5a;
            color: #1e1e2e;
        }

    .btn-retry {
        background: transparent;
        color: #ff8c42;
        border: 1px solid #ff8c42;
    }

        .btn-retry:hover {
            background: rgba(255, 140, 66, 0.1);
        }

    .error-note {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: #b0b0b0;
        font-size: 0.9rem;
    }

        .error-note a {
            color: #ff8c42;
            text-decoration: none;
        }

            .error-note a:hover {
                text-decoration: underline;
            }
</style>