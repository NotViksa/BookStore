@{
    ViewData["Title"] = "Page Not Found";
    Layout = "_Layout";
}

<div class="error-container">
    <div class="error-content">
        <div class="error-icon">
            <i class="bi bi-book"></i>
        </div>
        <h1 class="error-code">404</h1>
        <h2 class="error-title">Page Not Found</h2>
        <p class="error-message">The page you're looking for seems to have vanished from our shelves.</p>
        <div class="error-actions">
            <a asp-controller="Home" asp-action="Index" class="btn-home">
                <i class="bi bi-house-door"></i> Back to Home
            </a>
            <a asp-controller="Book" asp-action="Index" class="btn-browse">
                <i class="bi bi-book"></i> Browse Books
            </a>
        </div>
        <div class="error-suggestion">
            <p>You might want to check out these popular genres:</p>
            <div class="genre-suggestions">
                <a asp-controller="Book" asp-action="Index" asp-route-genre="Fiction">Fiction</a>
                <a asp-controller="Book" asp-action="Index" asp-route-genre="Fantasy">Fantasy</a>
                <a asp-controller="Book" asp-action="Index" asp-route-genre="Science Fiction">Science Fiction</a>
                <a asp-controller="Book" asp-action="Index" asp-route-genre="Mystery">Mystery</a>
            </div>
        </div>
    </div>
</div>

<style>
    .error-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .error-content {
        text-align: center;
        max-width: 600px;
    }

    .error-icon {
        font-size: 5rem;
        color: #ff8c42;
        margin-bottom: 1rem;
    }

    .error-code {
        font-size: 6rem;
        font-weight: bold;
        color: #ff8c42;
        margin-bottom: 0.5rem;
    }

    .error-title {
        font-size: 2rem;
        color: #fff;
        margin-bottom: 1rem;
    }

    .error-message {
        color: #b0b0b0;
        margin-bottom: 2rem;
    }

    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-bottom: 2rem;
    }

    .btn-home, .btn-browse {
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-home {
        background: #ff8c42;
        color: #1e1e2e;
    }

        .btn-home:hover {
            background: #ff9c5a;
            color: #1e1e2e;
        }

    .btn-browse {
        background: transparent;
        color: #ff8c42;
        border: 1px solid #ff8c42;
    }

        .btn-browse:hover {
            background: rgba(255, 140, 66, 0.1);
        }

    .error-suggestion p {
        color: #b0b0b0;
        margin-bottom: 0.5rem;
    }

    .genre-suggestions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
    }

        .genre-suggestions a {
            background: rgba(255, 140, 66, 0.1);
            color: #ff8c42;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .genre-suggestions a:hover {
                background: #ff8c42;
                color: #1e1e2e;
            }
</style>