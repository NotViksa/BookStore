@using System.Security.Claims
@inject BookStore.Services.Interfaces.ICartService CartService
@{
    var cartCount = 0;
    if (User.Identity.IsAuthenticated)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        cartCount = await CartService.GetCartItemCountAsync(userId);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/BookStore.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #0f0f1a;
            color: #e0e0e0;
        }
        /* Navbar */
        .navbar {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255, 140, 66, 0.3);
        }

        .navbar-brand {
            font-size: 1.5rem;
            font-weight: bold;
            color: #ff8c42 !important;
        }

            .navbar-brand i {
                color: #ff8c42;
            }

        .navbar-nav .nav-link {
            color: #e0e0e0 !important;
            transition: color 0.3s ease;
            padding: 0.5rem 0.75rem;
        }

            .navbar-nav .nav-link:hover {
                color: #ff8c42 !important;
            }
        /* Main content */
        main {
            min-height: calc(100vh - 200px);
            padding: 2rem 0 4rem 0;
        }

        .container {
            max-width: 1400px;
            padding: 0 2rem;
        }
        /* Footer */
        .footer {
            background: #1a1a2e;
            padding: 1.5rem 0;
            border-top: 1px solid rgba(255, 140, 66, 0.2);
            text-align: center;
            color: #b0b0b0;
        }
        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #1e1e2e;
        }

        .cart-badge {
            background: #ff8c42;
            color: #1e1e2e;
            border-radius: 50%;
            padding: 0.1rem 0.4rem;
            font-size: 0.7rem;
            margin-left: 0.3rem;
        }

        ::-webkit-scrollbar-thumb {
            background: #ff8c42;
            border-radius: 5px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #ff9c5a;
            }
        /* Responsive */
        @@media (max-width: 768px) {
            .container {
                padding: 0 1rem;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-book-fill me-2"></i>BookStore
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                                    <button type="submit" class="nav-link btn btn-link" style="color: #e0e0e0; text-decoration: none; background: none; border: none; padding: 0.5rem 0.75rem;">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>Home</a></li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Profile" asp-action="Index"><i class="bi bi-person me-1"></i>Profile</a></li>
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Book" asp-action="Index"><i class="bi bi-book me-1"></i>Browse</a></li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Book" asp-action="AddBook"><i class="bi bi-plus-circle me-1"></i>Add Book</a></li>
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About"><i class="bi bi-info-circle me-1"></i>About</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy"><i class="bi bi-shield-lock me-1"></i>Privacy</a></li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart"></i> Cart
                                @if (cartCount > 0)
                                {
                                    <span class="cart-badge">@cartCount</span>
                                }
                            </a>
                        </li>
                    </ul>
                    <div class="navbar-right">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>